direction: right

VPC: lab-vpc {
  PrivateSubnetA: {
    RDS_Primary: RDS (Primary) {
      style: { stroke: "#C44536"; stroke-width: 2 }
    }
  }
  PrivateSubnetB: {
    RDS_Standby: RDS (Standby) {
      style: { stroke: "#333333"; stroke-dash: 5 }
    }
  }
  
  RDS_Primary -> RDS_Standby: Synchronous Replication
}

